<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.zhjypt.mapper.TeacherMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.zhjypt.pojo.Teacher">
        <id column="teach_id" property="teachId" />
        <result column="teach_name" property="teachName" />
        <result column="teach_account" property="teachAccount" />
        <result column="teach_password" property="teachPassword" />
        <result column="teach_phone" property="teachPhone" />
        <result column="teach_email" property="teachEmail" />
        <result column="teach_address" property="teachAddress" />
        <result column="teach_birth" property="teachBirth" />
        <result column="teach_grade" property="teachGrade" />
        <result column="teach_class" property="teachClass" />
        <result column="del" property="del" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        teach_id, teach_name, teach_account, teach_password, teach_phone, teach_email, teach_address, teach_birth, teach_grade, teach_class, del
    </sql>

</mapper>
