<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.zhjypt.mapper.CourseMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.zhjypt.pojo.Course">
        <id column="course_id" property="courseId" />
        <result column="course_title" property="courseTitle" />
        <result column="course_desc" property="courseDesc" />
        <result column="course_cover" property="courseCover" />
        <result column="category_id" property="categoryId" />
        <result column="teacher_id" property="teacherId" />
        <result column="teacher_name" property="teacherName" />
        <result column="course_price" property="coursePrice" />
        <result column="course_duration" property="courseDuration" />
        <result column="student_count" property="studentCount" />
        <result column="course_status" property="courseStatus" />
        <result column="is_free" property="isFree" />
        <result column="difficulty_level" property="difficultyLevel" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="publish_time" property="publishTime" />
        <result column="del" property="del" />
        <result column="category_name" property="categoryName" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        course_id, course_title, course_desc, course_cover, category_id, teacher_id, 
        course_price, course_duration, student_count, course_status, is_free, difficulty_level, 
        create_time, update_time, publish_time, del
    </sql>

</mapper>